{
  "name": "@unifiedai/sdk",
  "version": "0.1.0",
  "description": "Official SDK for Unifiedai marketplace apps.",
  "type": "module",
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "main": "./dist/index.browser.js",
  "module": "./dist/index.browser.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.browser.js"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "default": "./dist/node/index.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.browser.js"
      },
      "default": "./dist/index.browser.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "default": "./dist/node/index.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist docs",
    "logos": "bun run scripts/generate-logos.ts",
    "build": "bun run clean && bun run logos && bun run build:browser && bun run build:node && bun run build:types && bun run build:verify",
    "prepare": "bun run build",
    "build:browser": "bun build ./src/index.ts --outdir dist --target browser --format esm --sourcemap --entry-naming index.browser.js",
    "build:node": "bun build ./src/node/index.ts --outdir dist/node --target node --format esm --sourcemap --external @napi-rs/keyring --entry-naming index.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build:verify": "bun run scripts/verify-browser-bundle.ts",
    "typecheck": "bun run logos && tsc --noEmit",
    "test": "bun run logos && bun test tests/core tests/node tests/bundle",
    "test:integration": "bun test tests/integration",
    "test:integration:record": "RECORD=true bun test tests/integration",
    "lint": "biome check .",
    "format": "biome format --write .",
    "docs": "typedoc",
    "demo": "bun install && bun examples/demo-app/run-app.ts",
    "changeset": "changeset",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@types/bun": "latest",
    "@types/node": "^20",
    "typedoc": "^0.26.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["unifiedai", "sdk", "llm", "marketplace"],
  "license": "MIT",
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0"
  }
}
